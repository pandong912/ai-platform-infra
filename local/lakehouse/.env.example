# Local-only defaults for the Iceberg lakehouse PoC.
# Copy this file to .env before changing values.

POSTGRES_DB=iceberg
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=iceberg
POSTGRES_PORT=15432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_WAREHOUSE_BUCKET=warehouse
MINIO_REGION=us-east-1
# If you change the MinIO credentials or bucket, also update
# config/trino/etc/catalog/iceberg.properties for this local PoC.
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

POLARIS_REALM=POLARIS
POLARIS_ROOT_CLIENT_ID=root
POLARIS_ROOT_CLIENT_SECRET=s3cr3t
POLARIS_CATALOG_NAME=quickstart_catalog
POLARIS_API_PORT=8181
POLARIS_MANAGEMENT_PORT=8182

TRINO_PORT=8081

SUPERSET_PORT=8088
SUPERSET_SECRET_KEY=replace-with-a-local-random-secret
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
